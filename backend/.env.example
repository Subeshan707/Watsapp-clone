PORT=5000
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>/<dbname>?retryWrites=true&w=majority

# AI chat bot (Groq)
GROQ_API_KEY=
# Optional
GROQ_MODEL=llama-3.1-8b-instant
AI_BOT_USERNAME=AI ChatBot

# ── SMS OTP Configuration ──
# Set to 'true' to send real SMS via Twilio (default: demo mode)
USE_REAL_SMS=false

# Twilio credentials (required when USE_REAL_SMS=true)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Option A: Twilio Verify Service (recommended — Twilio manages OTP)
TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Option B: Twilio SMS (manual OTP — you need a Twilio phone number)
TWILIO_PHONE_NUMBER=+1234567890

